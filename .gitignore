# Dependencies
node_modules/
**/node_modules/

# Lock files are regenerated locally on install; not tracked so that `git pull`
# never conflicts with the copy npm rewrites during build.bat.
package-lock.json
**/package-lock.json

# Build output
frontend/dist/
dist/

# Local database (user's private health data — never commit)
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal
backend/data/*.sqlite

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Env
.env
.env.local
